generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id            String   @id @default(cuid())
  storeId       String   @unique
  storeName     String
  storeAddress  String
  storeZipcode  String
  storeCity     String
  assortment    String   @default("")
  visitType     String   @default("Maintenance")
  visitFrequence String?
  salesRep      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeName])
  @@index([storeCity])
}

model Week {
  id        String   @id @default(cuid())
  weekNum   Int
  year      Int
  label     String
  excelUrl  String?
  createdAt DateTime @default(now())
  visits    Visit[]

  @@unique([weekNum, year])
}

model Visit {
  id            String   @id @default(cuid())
  weekId        String
  week          Week     @relation(fields: [weekId], references: [id])
  assortment    String
  storeId       String
  storeName     String
  storeAddress  String
  storeZipcode  String
  storeCity     String
  visitType     String
  visitFrequence String?
  visitDate     DateTime
  merchandiser  String?
  remarks       String?
  salesRep      String?
  materials     String?
  sortOrder     Int      @default(0)
  status        String   @default("pending")
  materialType  String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  notes         VisitNote[]
  photos        VisitPhoto[]
  modifications Modification[]

  @@index([storeId])
  @@index([visitDate])
  @@index([weekId, visitDate])
}

model VisitNote {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  storeId   String?
  content   String
  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([storeId])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  storeId   String?
  url       String
  blobKey   String
  caption   String?
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([storeId])
  @@index([starred])
}

model MailLog {
  id            String         @id @default(cuid())
  rawContent    String
  summary       String?
  replyDraft    String?
  status        String         @default("pending")
  createdAt     DateTime       @default(now())
  modifications Modification[]
}

model Modification {
  id          String   @id @default(cuid())
  mailLogId   String?
  mailLog     MailLog? @relation(fields: [mailLogId], references: [id])
  visitId     String?
  visit       Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  action      String
  target      String
  field       String?
  oldValue    String?
  newValue    String?
  description String
  applied     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([visitId])
}

model MaterialGuide {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  photoUrl  String?
  blobKey   String?
  updatedAt DateTime @updatedAt
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  term       String   @unique
  definition String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Settings {
  id          String   @id @default("singleton")
  openaiKey   String?
  userName    String?
  userZone    String?
  userEmail   String?
  homeAddress String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ContactTeam {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("bg-slate-50 border-slate-200 text-slate-700")
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
}

model Contact {
  id        String      @id @default(cuid())
  teamId    String
  team      ContactTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([teamId])
}